# Required
OPENAI_API_KEY=sk-your-openai-api-key

# Optional - API auth (empty = dev mode, no auth)
API_KEY=your-api-key

# Required for /admin/ingest and /admin/ingest-from-source
ADMIN_API_KEY=your-admin-key

# Optional - override defaults
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/support_ai
# REDIS_URL=redis://localhost:6379/0
# OPENSEARCH_HOST=http://localhost:9200
# QDRANT_HOST=localhost

# Reranker: local (needs http://localhost:8001), cohere (needs COHERE_API_KEY), or custom (no-op, use when no reranker service)
# RERANKER_PROVIDER=custom

# Retrieval (strong RAG: RRF fusion)
# RETRIEVAL_FUSION=rrf
# RETRIEVAL_RRF_K=60

# Intent-aware fetch: for plans/price queries, also fetch from these doc_types
# RETRIEVAL_PLANS_FETCH_DOC_TYPES=pricing
# RETRIEVAL_ENSURE_DOC_TYPE_MIN=2

# LLM (stored in DB app_config; env used as fallback when DB empty)
# Edit via Settings UI or PUT /admin/config/llm
# LLM_MODEL=gpt-4o-mini
# LLM_FALLBACK_MODEL=gpt-3.5-turbo
# OPENAI_API_KEY=sk-...  (also used as llm_api_key when not in DB)
# OPENAI_BASE_URL=      (optional; empty = default OpenAI URL)

# archi_v3
# LANGUAGE_DETECT_ENABLED=true
# NORMALIZER_USE_LLM=false
# NORMALIZER_LLM_MODEL=gpt-4o-mini
# EVIDENCE_EVALUATOR_ENABLED=false
# SELF_CRITIC_ENABLED=false
# SELF_CRITIC_REGENERATE_MAX=1
# FINAL_POLISH_ENABLED=false
# DECISION_ROUTER_USE_LLM=false
# DECISION_ROUTER_LLM_MODEL=gpt-4o-mini
